const { test, expect } = require('@playwright/test');

test('Sir johnSoane redirection', async ({ page }) => {
  await page.goto(process.env.SITE_URL, { waitUntil: 'domcontentloaded' });

  await page.locator('nav.m-main-nav a[href="/your-visit"]').click();

  await expect(page).toHaveURL(/your-visit/);
   await page.getByText('Book now').click();
    await page.locator('button.a-nav-toggle__wrapper').click();
    await page.locator('button.a-nav-toggle__wrapper').click();

// Verify all nav menu items are visible
const nav = page.locator('nav.m-main-nav--modal ul.menu');

await expect(nav.locator('a[href="/your-visit"]')).toBeVisible();
await expect(nav.locator('a[href="/whats-on"]')).toBeVisible();
await expect(nav.locator('a[href="/collections"]')).toBeVisible();
await expect(nav.locator('a[href="https://shop.soane.org"]')).toBeVisible();
await expect(nav.locator('a[href="/support-us"]')).toBeVisible();
await expect(nav.locator('a[href="/learning"]')).toBeVisible();
await expect(nav.locator('a[href="/soane-medal"]')).toBeVisible();
});